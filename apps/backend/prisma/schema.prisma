generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  status             String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  users              User[]
  campaigns          Campaign[]
  purchases          Purchase[]
  coupons            Coupon[]
  draws              Draw[]
  tenantCredits      TenantCredit[]
  creditTransactions CreditTransaction[]
}

model User {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  email     String   @unique
  password  String
  role      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Consumer {
  id        String     @id @default(cuid())
  cpf       String     @unique
  name      String
  phone     String
  email     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]
  coupons   Coupon[]
  drawWinners DrawWinner[]
}

model Campaign {
  id                    String     @id @default(cuid())
  tenantId              String     @map("tenant_id")
  title                 String
  description           String
  startDate             DateTime   @map("start_date")
  endDate               DateTime   @map("end_date")
  minimumValuePerCoupon Decimal    @map("minimum_value_per_coupon") @db.Decimal(10, 2)
  active                Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  tenant                Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases             Purchase[]
  coupons               Coupon[]
  draws                 Draw[]

  @@index([tenantId])
}

model Purchase {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  campaignId   String   @map("campaign_id")
  consumerId   String   @map("consumer_id")
  amount       Decimal  @db.Decimal(10, 2)
  purchaseDate DateTime @map("purchase_date")
  createdAt    DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  consumer Consumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  coupons  Coupon[]

  @@index([tenantId])
  @@index([campaignId])
  @@index([consumerId])
}

model Coupon {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  campaignId String   @map("campaign_id")
  consumerId String   @map("consumer_id")
  purchaseId String   @map("purchase_id")
  couponCode String   @unique @map("coupon_code")
  generatedAt DateTime @default(now()) @map("generated_at")
  active     Boolean  @default(true)
  drawWinners DrawWinner[]

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  consumer Consumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([campaignId])
  @@index([consumerId])
  @@index([purchaseId])
}

model Draw {
  id String @id @default(cuid())
  tenantId String @map("tenant_id")
  campaignId String @map("campaign_id")
  drawnAt DateTime @map("drawn_at")
  quantity Int
  seed String
  seedHash String @map("seed_hash")
  createdByUserId String? @map("created_by_user_id")
  createdAt DateTime @default(now())
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  winners DrawWinner[]

  @@index([tenantId])
  @@index([campaignId])
}

model DrawWinner {
  id String @id @default(cuid())
  drawId String @map("draw_id")
  couponId String @map("coupon_id")
  consumerId String @map("consumer_id")
  position Int
  createdAt DateTime @default(now())
  draw Draw @relation(fields: [drawId], references: [id], onDelete: Cascade)
  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  consumer Consumer @relation(fields: [consumerId], references: [id], onDelete: Cascade)

  @@index([drawId])
}

model CreditPackage {
  id String @id @default(cuid())
  name String
  quantity Int
  price Decimal @db.Decimal(10,2)
  active Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TenantCredit {
  id String @id @default(cuid())
  tenantId String @map("tenant_id")
  balance Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId])
}

model CreditTransaction {
  id String @id @default(cuid())
  tenantId String @map("tenant_id")
  type String
  quantity Int
  amount Decimal @db.Decimal(10,2)
  status String
  paymentMethod String?
  pixKey String? @map("pix_key")
  pixQrCode String? @map("pix_qr_code")
  pixCopyPaste String? @map("pix_copy_paste")
  packageName String? @map("package_name")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}
